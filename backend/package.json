{
  "name": "@insula/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --dir src --exclude '**/*.integration.test.ts'",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "test:integration:docker": "bash scripts/run-integration-tests.sh",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:generate": "drizzle-kit generate",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.102.0",
    "@aws-sdk/client-s3": "^3.1063.0",
    "@aws-sdk/lib-storage": "^3.1063.0",
    "@aws-sdk/s3-request-presigner": "^3.1063.0",
    "@fastify/compress": "^8.3.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.1.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@fastify/websocket": "^11.2.0",
    "@insula/api-contracts": "*",
    "@kubernetes/client-node": "^1.4.0",
    "@simplewebauthn/server": "^13.3.1",
    "@types/archiver": "^7.0.0",
    "@types/mjml": "^5.0.0",
    "@types/ssh2": "^1.15.5",
    "@types/yauzl": "^3.3.0",
    "archiver": "^5.3.2",
    "archiver-zip-encrypted": "^2.0.0",
    "bcrypt": "^6.0.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "handlebars": "^4.7.9",
    "js-yaml": "^4.2.0",
    "lru-cache": "^11.5.1",
    "mjml": "^5.3.0",
    "nodemailer": "^8.0.10",
    "openai": "^6.42.0",
    "pg": "^8.21.0",
    "pg-boss": "^12.18.2",
    "ssh2": "^1.17.0",
    "tar-stream": "^3.2.0",
    "yauzl": "^3.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.2",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.11.0",
    "@types/tar-stream": "^3.1.4",
    "@vitest/coverage-v8": "^4.1.8",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.1",
    "pg-mem": "^3.0.14",
    "postject": "^1.0.0-alpha.6",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.4"
  }
}
