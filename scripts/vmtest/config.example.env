# scripts/vmtest/config.example.env — copy to config.env and edit.
# Ephemeral VM integration-test tier. See docs/development/EPHEMERAL_VM_INTEGRATION_TESTING.md.
# NOTHING here runs until you set VMTEST_DRIVER and its enablement (socket mount or host SSH).

# ── Driver / transport ──────────────────────────────────────────────
# libvirt-sock : virsh over a host libvirt socket mounted into this env
# ssh-host     : virsh over qemu+ssh to the Unraid host
VMTEST_DRIVER="${VMTEST_DRIVER:-}"                 # REQUIRED: libvirt-sock | ssh-host

# libvirt-sock: the URI to the (mounted) local socket
VMTEST_LOCAL_URI="qemu:///system"
# ssh-host: the Unraid host libvirtd reached over SSH (native libvirt remote)
VMTEST_HOST_SSH="root@unraid.lan"                  # user@host of the Unraid box
VMTEST_HOST_SSH_KEY="$HOME/.ssh/unraid_vmtest"

# Where qcow2 golden + overlays live. MUST be readable by the host's qemu.
# libvirt-sock: bind-mount this same path into this env. ssh-host: a host path.
VMTEST_POOL_DIR="/mnt/user/vmtest"

# ── OS selection (full supported matrix in lib/os-registry.sh) ──────
# Any id from os-registry: debian-12|debian-13|ubuntu-22.04|ubuntu-24.04|
# rocky-9|alma-9|centos-stream-9|centos-stream-10|amazonlinux-2023.
VMTEST_OS="${VMTEST_OS:-debian-13}"                # single-run default
# --os-matrix iterates this set (a throw-away cluster PER OS → real multi-OS
# compatibility). Default = both tier-1 families + one tier-2 = a strong signal
# without paying for all 8. Set to more/all for a full compatibility sweep.
VMTEST_OS_MATRIX="${VMTEST_OS_MATRIX:-debian-13 ubuntu-24.04 rocky-9}"
# Golden path is derived per-OS: ${VMTEST_POOL_DIR}/golden-<os>.qcow2

# ── Cluster shape ───────────────────────────────────────────────────
VMTEST_SERVERS=1                                   # control-plane count
VMTEST_WORKERS=3                                   # Longhorn wants >=3 nodes for replica spread
VMTEST_VCPU=2
VMTEST_RAM_MB=4096
VMTEST_DISK_GB=40
VMTEST_MODE="cold"                                 # cold = run bootstrap.sh | warm = post-bootstrap snapshot

# ── Network / DNS / apex ────────────────────────────────────────────
# Per-run NAT net + apex. <run> is injected so parallel runs never collide.
VMTEST_SUBNET_BASE="10.98"                          # <base>.<run-octet>.0/24
VMTEST_APEX_TMPL="t%s.insula.test"                  # %s <- short run id  → e.g. tab12cd.insula.test

# ── ACME / TLS fidelity ─────────────────────────────────────────────
# pebble    : local test CA, no rate limit (default, every run)
# le-staging: real Let's Encrypt staging (needs a publicly delegated zone)
VMTEST_ACME_TIER="pebble"

# ── Backup target ───────────────────────────────────────────────────
VMTEST_BACKUP="minio"                              # minio | nfs | none

# ── Integration run ─────────────────────────────────────────────────
VMTEST_INTEGRATION_ARGS=""                          # e.g. "--tier core" or "--only postgres-pitr"
VMTEST_KEEP_ON_FAIL=0                               # 1 = skip teardown when a run fails (for debugging)
