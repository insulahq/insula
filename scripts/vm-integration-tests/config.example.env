# scripts/vm-integration-tests/config.example.env — copy to config.env and edit.
# Ephemeral VM integration-test tier. See docs/development/EPHEMERAL_VM_INTEGRATION_TESTING.md.
# NOTHING here runs until you set VMTEST_DRIVER and its enablement (socket mount or host SSH).

# ── Driver / transport ──────────────────────────────────────────────
# libvirt-sock : virsh over a host libvirt socket mounted into this env
# ssh-host     : virsh over qemu+ssh to the Unraid host
VMTEST_DRIVER="${VMTEST_DRIVER:-}"                 # REQUIRED: libvirt-sock | ssh-host

# libvirt-sock: the URI to the (mounted) local socket
VMTEST_LOCAL_URI="qemu:///system"
# ssh-host: the Unraid host libvirtd reached over SSH (native libvirt remote)
VMTEST_HOST_SSH="root@unraid.lan"                  # user@host of the Unraid box
VMTEST_HOST_SSH_KEY="$HOME/.ssh/unraid_vmtest"

# ── Storage paths ───────────────────────────────────────────────────
# Two classes of path, don't mix them up:
#   HOST paths  — qemu reads these; on ssh-host they live on the Unraid box, on
#                 libvirt-sock they must be bind-mounted at the SAME path here.
#   LOCAL paths — this env writes/reads these (SSH keys, cloud-init, reports).
#
# VMTEST_POOL_DIR is just the default PARENT for the host dirs; override any
# sub-path individually (e.g. cache OS images on bulk storage, put fast-churning
# VM disks on SSD).
VMTEST_POOL_DIR="${VMTEST_POOL_DIR:-/mnt/user/vmtest}"
# HOST: cached OS base images (goldens) — large, persistent across runs.
VMTEST_IMAGE_CACHE_DIR="${VMTEST_IMAGE_CACHE_DIR:-${VMTEST_POOL_DIR}/images}"
# HOST: per-run VM disk overlays + seed ISOs + libvirt XML — ephemeral, churny.
VMTEST_DISK_DIR="${VMTEST_DISK_DIR:-${VMTEST_POOL_DIR}/disks}"
# LOCAL: scratch in THIS env (ephemeral SSH keys, cloud-init user/meta-data).
VMTEST_TMP_DIR="${VMTEST_TMP_DIR:-/tmp}"
# LOCAL: integration run reports (written by the local integration-all.sh).
VMTEST_REPORT_DIR="${VMTEST_REPORT_DIR:-${VMTEST_TMP_DIR%/}/vmtest-reports}"

# ── OS selection: RANDOM per node (matrix in lib/os-registry.sh) ────
# Every node draws a random OS from the pool → a HETEROGENEOUS cluster per run
# (real scenario: operators add nodes over time on whatever OS is current), and
# coverage over the whole matrix accumulates across runs. PR / nightly / pre-
# release ALL use this same model — they differ in node count / suite scope / how
# many runs, NOT in OS strategy. No fixed set, never all-at-once.
#
# Pool = the randomisation universe. Empty ⇒ ALL supported OSes with a real image
# URL (os_pool_default: debian-12/13, ubuntu-22.04/24.04, rocky-9, alma-9,
# centos-stream-9/10 — AL2023 excluded until its URL is pinned).
VMTEST_OS_POOL="${VMTEST_OS_POOL:-}"
# Reproducibility: the draw is SEEDED. Set to replay a past run's exact assignment
# (spawn-cluster prints it as os-seed=…). Empty ⇒ fresh random each run.
VMTEST_OS_SEED="${VMTEST_OS_SEED:-}"
# Debug override: pin EVERY node to one OS (homogeneous). Empty ⇒ random per node.
VMTEST_OS="${VMTEST_OS:-}"
# Golden path is derived per-OS: ${VMTEST_IMAGE_CACHE_DIR}/golden-<os>.qcow2

# ── Cluster shape ───────────────────────────────────────────────────
# 3 servers + 1 worker: HA mode REQUIRES >=3 server nodes — etcd quorum, CNPG
# 1->3 instances, Deployments 2->3 with per-node topologySpread; the Apply-HA
# button is DISABLED below 3 servers (docs/architecture/HA_MODE.md). 1 server
# cannot test HA at all. The 3 servers are also the system/CNPG nodes; the
# worker covers the worker role (tenant workloads, drain targets). 4 cluster
# nodes total — same footprint as 1s+3w, just the role split that tests HA.
# All env-overridable (${VAR:-default}) so a caller can e.g. VMTEST_SERVERS=1 for a
# single-node P0 smoke without editing this file — config is sourced, so plain
# assignments here would otherwise clobber the caller's exported env.
VMTEST_SERVERS="${VMTEST_SERVERS:-3}"              # >=3 for HA (etcd quorum + CNPG/Longhorn spread)
VMTEST_WORKERS="${VMTEST_WORKERS:-1}"             # worker-role coverage
VMTEST_VCPU="${VMTEST_VCPU:-2}"
VMTEST_RAM_MB="${VMTEST_RAM_MB:-4096}"
VMTEST_DISK_GB="${VMTEST_DISK_GB:-40}"
VMTEST_MODE="${VMTEST_MODE:-cold}"                 # cold = run bootstrap.sh | warm = post-bootstrap snapshot
# bootstrap --env: which overlay to test. `staging`/`production` = what actually
# ships (real Let's Encrypt ClusterIssuer — which can't validate the internal apex, so
# TLS certs stay pending and Traefik serves its DEFAULT self-signed cert; the harness
# runs curl -k so api/curl suites are UNAFFECTED — only cert-CHAIN-asserting suites need
# Pebble wired as the ACME server, deferred). `dev` = local-ca-issuer (self-signed,
# works internally) + Dex/dev conveniences.
# NOTE: reachability model — run.sh ships scripts/ to the control-plane node and runs
# integration-all THERE (LOCAL_KUBECTL=1). Only a cluster node both resolves the private
# apex (node resolver = services-VM dnsmasq → PowerDNS wildcard, seeded post-bootstrap)
# and routes to the in-cluster ingress; this env reaches the NAT'd nodes only via SSH.
VMTEST_ENV="${VMTEST_ENV:-dev}"

# ── Network / DNS / apex ────────────────────────────────────────────
# Per-run NAT net + apex. <run> is injected so parallel runs never collide.
VMTEST_SUBNET_BASE="${VMTEST_SUBNET_BASE:-10.98}"   # <base>.<run-octet>.0/24
# %s <- short run id → e.g. tab12cd.insula.host. `.host` is a VALID public-suffix
# gTLD (unlike reserved `.test`), so Pebble accepts ACME contact emails at the apex
# (both cert-manager AND Stalwart's hostmaster@<apex>). PowerDNS is authoritative for
# the per-run apex + dnsmasq only routes <apex> to it, so it never leaves the run net.
VMTEST_APEX_TMPL="${VMTEST_APEX_TMPL:-t%s.insula.host}"

# ── Services VM (DNS/ACME/S3 in its OWN Docker — never the host's) ──
# PowerDNS + Pebble + MinIO run in a throw-away VM's Docker on the run's NAT net,
# so the rig needs NO host Docker / docker.sock — libvirt is the only host
# privilege. Services don't need OS randomisation, so this VM is pinned to Debian.
VMTEST_SVC_OS="${VMTEST_SVC_OS:-debian-13}"
VMTEST_SVC_VCPU="${VMTEST_SVC_VCPU:-1}"
VMTEST_SVC_RAM_MB="${VMTEST_SVC_RAM_MB:-1536}"
VMTEST_SVC_DISK_GB="${VMTEST_SVC_DISK_GB:-20}"
# vm       : dedicated services VM (default; keeps cluster nodes pristine)
# colocate : run this Docker on the control-plane VM to save one VM's RAM
#            (documented follow-up — not yet wired)
VMTEST_SVC_MODE="${VMTEST_SVC_MODE:-vm}"

# ── ACME / TLS fidelity ─────────────────────────────────────────────
# pebble    : local test CA, no rate limit (default, every run)
# le-staging: real Let's Encrypt staging (needs a publicly delegated zone)
VMTEST_ACME_TIER="${VMTEST_ACME_TIER:-pebble}"
# ACME account contact email (cert-manager LE issuer). Empty ⇒ spawn-cluster uses
# admin@<apex>, which is fine now the apex TLD (.host) is a valid public suffix.
# Set an explicit valid-suffix address only if you point the apex at a reserved TLD
# again, or a real deliverable one for le-staging. (Stalwart derives its own mail
# ACME contact as hostmaster@<apex>, also valid under .host.)
VMTEST_ACME_EMAIL="${VMTEST_ACME_EMAIL:-}"
# TLS verification during the run. EMPTY (default) = the harness VERIFIES the platform's
# certs — bootstrap points cert-manager at the run's Pebble via --acme-server, the certs
# ISSUE for the private apex (real ACME path, test CA), and run.sh trusts Pebble's root on
# the CP, so a bad/missing cert FAILS a suite exactly as on a real cluster. Set to 1 only to
# force insecure curls (-k) — e.g. when running WITHOUT the Pebble services VM. run.sh
# auto-falls back to 1 when no Pebble IP is present.
VMTEST_CURL_INSECURE="${VMTEST_CURL_INSECURE:-}"

# ── Backup target ───────────────────────────────────────────────────
VMTEST_BACKUP="${VMTEST_BACKUP:-minio}"            # minio | nfs | none

# ── Integration run ─────────────────────────────────────────────────
VMTEST_INTEGRATION_ARGS="${VMTEST_INTEGRATION_ARGS:-}"   # e.g. "--tier core" or "--only postgres-pitr"
VMTEST_KEEP_ON_FAIL="${VMTEST_KEEP_ON_FAIL:-0}"    # 1 = skip teardown when a run fails (for debugging)
