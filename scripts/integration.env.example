# integration.env.example — copy to scripts/integration.env and fill in.
#
#   cp scripts/integration.env.example scripts/integration.env
#   $EDITOR scripts/integration.env
#
# scripts/integration.env is GITIGNORED. Put your real cluster coordinates and
# any confidential external-target credentials here — NEVER in a committed
# script. The harnesses source this file via load_integration_env()
# (scripts/lib/integration-env.sh) before applying their own defaults, so these
# values win. You can also point at a profile elsewhere with INTEGRATION_ENV=/path.
#
# This repo is public OSS: committed scripts contain only example.test /
# placeholder values. scripts/ci-no-hardcoded-test-infra.sh fails CI if a real
# node IP or operator domain is committed.

# ─── Cluster access (mandatory for any suite) ─────────────────────────────────
# Admin API + credentials. ADMIN_PASSWORD is required by every suite.
ADMIN_HOST=https://admin.<your-apex>
ADMIN_EMAIL=admin@<your-apex>
ADMIN_PASSWORD=

# SSH into a control-plane node for in-cluster kubectl probes.
# SSH_HOST is required by suites that run cluster-internal checks.
SSH_HOST=root@<node-ip-or-host>
SSH_KEY=$HOME/hosting-platform.key
# CONTROL_HOST defaults to SSH_HOST; override only if the control plane is
# reachable on a different address than your bastion.
#CONTROL_HOST=root@<control-plane-ip>

# ─── Test fixtures that depend on your DNS ────────────────────────────────────
# Wildcard zone that resolves to the cluster ingress IPs. Required by the HTTPS
# tenant-provisioning scenario (a real cert is issued against a subdomain here).
HTTPS_TEST_DOMAIN_BASE=<wildcard-zone-you-control>

# Catalog entry UUID for the generic nginx+PHP runtime, if your cluster's
# catalog differs from the seeded default. Look up via:
#   GET /api/v1/catalog?limit=200
#CATALOG_NGINX_PHP=

# ─── Optional external / confidential targets ────────────────────────────────
# Suites that exercise off-site or third-party systems use require_or_skip():
# leave these blank and those suites SKIP (exit 77) cleanly instead of failing.
# Fill them in to enable the suite against your private infrastructure.

# Off-site S3-compatible backup target (backup round-trip / DR suites).
#BACKUP_S3_ENDPOINT=
#BACKUP_S3_REGION=
#BACKUP_S3_BUCKET=
#BACKUP_S3_ACCESS_KEY=
#BACKUP_S3_SECRET_KEY=

# External SMTP relay (outbound mail-deliverability suites).
#SMTP_RELAY_HOST=
#SMTP_RELAY_PORT=587
#SMTP_RELAY_USER=
#SMTP_RELAY_PASSWORD=

# Third-party / external API tokens (provider-specific suites).
#EXTERNAL_DNS_API_TOKEN=
#EXTERNAL_OIDC_ISSUER=

# ─── Behaviour toggles ───────────────────────────────────────────────────────
#INTEGRATION_PARALLEL=1          # 0 = run the parallel bucket serially (debug)
#INTEGRATION_ENV_VERBOSE=1       # log which profile file was loaded
