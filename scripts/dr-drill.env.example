# dr-drill.env.example — copy to scripts/dr-drill.env (gitignored) and fill in.
#
#   cp scripts/dr-drill.env.example scripts/dr-drill.env && chmod 600 scripts/dr-drill.env
#
# These values are confidential (age private key, drill VM, report token) —
# that is precisely why the DR drill runs LOCALLY or on a PRIVATE host and is
# NEVER wired into public-repo GitHub Actions. Do not commit scripts/dr-drill.env.
# Flags passed to dr-drill.sh override anything set here.

# ── required (all modes) ─────────────────────────────────────────────
# Path to the age-encrypted Tier-1 secrets bundle (.tar.age) under test.
# Fetch a fresh one with:  make secrets-fetch HOST=root@<server>
DR_DRILL_BUNDLE=/var/lib/hosting-platform/bundles/secrets-bundle.tar.age

# Path to the operator's age PRIVATE key that decrypts the bundle.
DR_DRILL_AGE_KEY=/home/operator/.age/operator.key

# ── default mode ─────────────────────────────────────────────────────
# validate | dind | bootstrap   (overridden by --mode)
DR_DRILL_MODE=validate

# ── required for --mode bootstrap only ───────────────────────────────
# Throwaway VM to recover ONTO (wiped + re-bootstrapped from the bundle).
# NEVER point this at a live cluster.
DR_DRILL_TARGET=root@drill-vm.example.test
DR_DRILL_SSH_KEY=/home/operator/hosting-platform.key
DR_DRILL_DOMAIN=drill.example.test
# Extra flags appended verbatim to bootstrap.sh (e.g. --mail-port-mode haproxy).
DR_DRILL_BOOTSTRAP_ARGS=

# ── reliability ──────────────────────────────────────────────────────
# Wall-clock cap (seconds) for the restore/bootstrap phase. Default 1800.
DR_DRILL_TIMEOUT=1800

# ── optional reporting ───────────────────────────────────────────────
# Write the JSON report to a file instead of stdout.
# DR_DRILL_REPORT=/var/log/dr-drill/last.json
# POST the JSON report to the platform-api DR-drill ingestion endpoint so the
# admin "DR Drill" tab surfaces history (TLS-verified unless
# DR_DRILL_WEBHOOK_INSECURE=1). The token is a long-lived JWT for a super_admin
# service account. Reach the endpoint over a private/mesh network, not the
# public internet.
# DR_DRILL_WEBHOOK_URL=https://admin.<apex>/api/v1/system-backup/dr-drill/runs
# DR_DRILL_WEBHOOK_TOKEN=replace-with-a-super_admin-service-jwt
# DR_DRILL_WEBHOOK_INSECURE=0
# Provenance label recorded in the report (cron|workflow_dispatch|manual|meta_test).
# DR_DRILL_TRIGGER=cron
# DR_DRILL_RUNNER=ops-host-1
